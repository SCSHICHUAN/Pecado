{
  "name": "pecado",
  "productName": "Pecado",
  "version": "1.0.0",
  "description": "Pecado — Electron desktop AI coding assistant with Volc Ark, MCP filesystem; Xcode tools on macOS only.",
  "config": {
    "electron_mirror": "https://npmmirror.com/mirrors/electron/"
  },
  "main": "src/main/js/main.js",
  "scripts": {
    "postinstall": "node ./node_modules/electron/install.js",
    "start": "node src/electron/shell/dev.js",
    "dev": "node src/electron/shell/dev.js",
    "start:shell": "bash src/electron/shell/quick-start.sh",
    "env:init": "node src/electron/init/init-env.js",
    "build": "ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --win --x64",
    "build:mac": "ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --x64",
    "build:win": "ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64",
    "build:linux": "ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder --linux --x64"
  },
  "build": {
    "extends": "./config/electron-builder.json"
  },
  "keywords": [
    "electron",
    "pecado",
    "ai-agent",
    "mcp"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "monaco-editor": "^0.55.1",
    "xcode": "^3.0.1"
  }
}
